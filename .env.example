# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
# MED-06 : adresse bind (127.0.0.1 derrière un proxy Nginx, 0.0.0.0 sinon)
HOST=0.0.0.0

# ─── Base de données PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fait_maison
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ─── JWT — OBLIGATOIRE : minimum 32 caractères aléatoires ────────────────────
JWT_SECRET=changez_ce_secret_par_une_chaine_aleatoire_de_min_32_chars
JWT_REFRESH_SECRET=autre_secret_refresh_min_32_chars_different_du_jwt_secret
JWT_EXPIRES_IN=1h

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# ─── Cloudinary (upload images) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Orange Money ─────────────────────────────────────────────────────────────
ORANGE_CLIENT_ID=your_orange_client_id
ORANGE_CLIENT_SECRET=your_orange_client_secret
ORANGE_MERCHANT_KEY=your_merchant_key
ORANGE_RETURN_URL=https://your-domain.com/paiement/succes
ORANGE_CANCEL_URL=https://your-domain.com/paiement/annule
ORANGE_NOTIF_URL=https://your-domain.com/faitMaison/paiement/webhook/orange

# URL API Orange Money — dev: .../dev/v1  |  prod: .../prod/v1
ORANGE_API_BASE=https://api.orange.com/orange-money-webpay/dev/v1

# HMAC secret pour vérifier les notifications webhook Orange Money (OBLIGATOIRE en prod)
ORANGE_WEBHOOK_SECRET=votre_secret_hmac_fourni_par_orange_money

# ─── Resend (emails transactionnels) ─────────────────────────────────────────
# Créer un compte sur https://resend.com et ajouter votre domaine vérifié
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Adresse expéditrice (doit utiliser votre domaine vérifié sur Resend en prod)
MAIL_FROM=Fait Maison <noreply@votre-domaine.com>

# ─── Firebase / FCM (notifications push) ─────────────────────────────────────
# Coller le JSON complet du service account Firebase (sur une seule ligne, échappé)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ─── Admin — OBLIGATOIRE pour npm run seed ────────────────────────────────────
# CRIT-01 : aucun fallback hardcodé — ces variables DOIVENT être définies
ADMIN_EMAIL=admin@votre-domaine.com
ADMIN_PASSWORD=VotreMotDePasse_Min12Chars!
